{
  "manifest_version": 3,
  "name": "e-Okul Gelişim Düzeyi Sihirbazı",
  "version": "3.4.0",
  "description": "Excel'den e-Okul'a otomatik Gelişim Düzeyi girişi. Saatler süren işi dakikalara indirin!",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://e-okul.meb.gov.tr/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://e-okul.meb.gov.tr/*"],
      "js": ["libs/xlsx.full.min.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["libs/xlsx.full.min.js"],
      "matches": ["https://e-okul.meb.gov.tr/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
